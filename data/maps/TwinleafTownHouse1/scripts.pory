mapscripts TwinleafTownHouse1_MapScripts{
}

script TwinleafTownHouse1_EventScript_Man {
	lock
	faceplayer
	if(var(VAR_LAKE_VERITY_STATE) == 3) {
		msgbox("I went on an adventure with some\n"
				"Pokémon a long time ago.\p"
				"It was only to Sandgem, the next town\n"
				"over, though. Yeah, good times. . .")
	} else {
		msgbox("You're off to hang with Barry\n"
		"again, right? You two sure are tight!")
	}
	release

}
